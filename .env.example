# Supabase — copy this file to `.env` and fill in the values from your
# Supabase project: Dashboard → Project Settings → API.
# Both values are safe to expose in the client bundle (the anon key is
# protected by Row Level Security). Never put the service_role key here.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
